# RAG-Anything Sidecar Configuration
# Copy to .env and fill in values

# Server
HOST=0.0.0.0
PORT=8001

# LLM API (OpenAI-compatible)
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Vision Model (for image description)
VISION_API_KEY=your-api-key
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o

# Embedding Model
EMBEDDING_API_KEY=your-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# PostgreSQL source of truth for optional turbovec rebuilds
DATABASE_URL=postgresql://ai:ai_password@localhost:5433/ai_sales

# Optional turbovec vector accelerator
VECTOR_SEARCH_PROVIDER=pgvector
TURBOVEC_ENABLED=false
TURBOVEC_INDEX_DIR=.data/turbovec
TURBOVEC_BIT_WIDTH=4

# Document Parser: "mineru" | "docling" | "paddleocr"
PARSER_BACKEND=mineru

# Knowledge Graph
ENABLE_KNOWLEDGE_GRAPH=true

# NestJS API callback for status updates
NESTJS_API_URL=http://localhost:4000
NESTJS_API_KEY=
