# App
NODE_ENV=development
APP_URL=http://localhost:3100
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://ai:ai_password@localhost:5433/ai_sales
TEST_DATABASE_URL=postgresql://ai:ai_password@localhost:5434/ai_sales_test

# Redis
REDIS_URL=redis://localhost:6380

# Security
# Generate unique production values before deploy. Example:
# openssl rand -base64 48
JWT_SECRET=replace_with_48_byte_random_secret
ENCRYPTION_KEY=replace_with_32_byte_random_key
ADMIN_JWT_EXPIRES_IN=8h

# AI Provider
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_EMBEDDING_MODEL=deepseek-embedding

# Embedding
EMBEDDING_PROVIDER=mock
VECTOR_DB_PROVIDER=pgvector
VECTOR_SEARCH_PROVIDER=pgvector
RAG_SIDECAR_ENABLED=true
RAG_SIDECAR_URL=http://localhost:8001
RAG_SIDECAR_TIMEOUT_MS=90000
TURBOVEC_ENABLED=false
TURBOVEC_BASE_URL=http://localhost:8001
TURBOVEC_SEARCH_TIMEOUT_MS=800
TURBOVEC_REBUILD_ON_START=false
TURBOVEC_MIN_CHUNKS=50000
TURBOVEC_TOPK_MULTIPLIER=4

# Mock (HARNESS)
MOCK_AI_ENABLED=true
MOCK_AI_LATENCY_MS=300

# Doudian
DOUDIAN_MODE=mock
DOUDIAN_APP_KEY=
DOUDIAN_APP_SECRET=
DOUDIAN_REDIRECT_URI=http://localhost:4000/api/integrations/doudian/oauth/callback

# Xiaohongshu (小红书三方客服)
XHS_CRYPTO_KEY=               # 32 hex chars (16 bytes) for AES-128-CBC message encryption
XHS_APP_ID=                   # Xiaohongshu Open Platform app ID
XHS_APP_SECRET=               # Optional legacy OAuth secret; documented third-party binding does not require it
XHS_ACCESS_TOKEN=             # Default API access token (can be overridden per account)
XHS_WEBHOOK_VERIFY=false      # Set to "true" to enable HMAC-SHA256 webhook signature verification

# Miniapp
DOUYIN_MINIAPP_APP_ID=
DOUYIN_MINIAPP_APP_SECRET=
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=

# File Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio_password
MINIO_BUCKET=ai-sales

# RAG sidecar optional model settings
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
VISION_API_KEY=
VISION_BASE_URL=https://api.openai.com/v1
VISION_MODEL=gpt-4o
ENABLE_KNOWLEDGE_GRAPH=false

# Notification
WE_COM_WEBHOOK_URL=
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# Webhook
WEBHOOK_SECRET=mock_webhook_secret

# ChatGPT-On-CS Sidecar (多平台消息桥接)
CHATGPT_ON_CS_ENABLED=false
CHATGPT_ON_CS_API_URL=http://localhost:3001
CHATGPT_ON_CS_WEBHOOK_SECRET=

# Juguang (聚光) Integration
JUGUANG_APP_ID=
JUGUANG_APP_SECRET=
JUGUANG_ACCESS_TOKEN=
