{
  "name": "ai-commerce-assistant",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@8.11.0",
  "scripts": {
    "dev": "turbo dev",
    "api:prepare": "tsx scripts/wait-for-runtime-deps.ts && tsx scripts/ensure-db-migrations.ts",
    "db:ensure": "tsx scripts/ensure-db-migrations.ts",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:stop": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "monitor:runtime": "powershell -ExecutionPolicy Bypass -File .\\scripts\\monitor-runtime.ps1",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:api": "vitest run tests/integration/api",
    "test:rag": "tsx tests/evals/run-rag-eval.ts",
    "test:ai-safety": "tsx tests/evals/run-ai-safety-eval.ts",
    "test:doudian-mock": "tsx tests/scripts/test-doudian-mock.ts",
    "test:miniapp-mock": "tsx tests/scripts/test-miniapp-mock.ts",
    "test:db:push": "tsx tests/scripts/push-test-schema.ts",
    "test:infra:up": "tsx tests/scripts/test-infra.ts up",
    "test:infra:down": "tsx tests/scripts/test-infra.ts down",
    "test:infra:restart": "tsx tests/scripts/test-infra.ts restart",
    "test:sidecar:live": "tsx tests/scripts/check-sidecar-live.ts",
    "test:webhook": "tsx tests/scripts/send-mock-webhooks.ts",
    "test:tenant-isolation": "vitest run tests/integration/tenant-isolation.test.ts",
    "seed:test": "pnpm --dir packages/database exec tsx ../../tests/scripts/seed-test-data.ts",
    "reset:test": "pnpm --dir packages/database exec tsx ../../tests/scripts/reset-test-db.ts",
    "mock:start": "tsx harness/mock-server/index.ts",
    "validate:quick": "pnpm lint && pnpm typecheck && pnpm test",
    "validate": "pnpm validate:quick && pnpm test:e2e && pnpm test:ai-safety && pnpm test:webhook && pnpm test:doudian-mock && pnpm test:miniapp-mock",
    "validate:release": "tsx tests/scripts/validate-release.ts",
    "validate:mvp": "pnpm test:infra:up && pnpm test:db:push && pnpm seed:test && pnpm test:api && pnpm test:rag && pnpm test:infra:down",
    "validate:before-commit": "pnpm validate:quick"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "15.5.15",
    "eslint": "^9.39.4",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-react-hooks": "^7.1.1",
    "pm2": "^7.0.1",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^3.1.0"
  }
}
